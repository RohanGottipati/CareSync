# ── Backboard ──────────────────────────────────────
BACKBOARD_API_KEY=your_backboard_api_key_here
BACKBOARD_BASE_URL=https://app.backboard.io/api
BACKBOARD_HANDOFF_AGENT_ID=your_handoff_agent_id
BACKBOARD_SENTINEL_AGENT_ID=your_sentinel_agent_id
BACKBOARD_FAMILY_AGENT_ID=your_family_agent_id

# ── Auth0 ───────────────────────────────────────────
AUTH0_DOMAIN=your-app.us.auth0.com
AUTH0_AUDIENCE=https://wardround-api

# ── Vultr Object Storage (S3-compatible) ────────────
VULTR_STORAGE_ACCESS_KEY=your_access_key
VULTR_STORAGE_SECRET_KEY=your_secret_key
VULTR_STORAGE_ENDPOINT=https://ewr1.vultrobjects.com
VULTR_STORAGE_BUCKET=wardround-documents

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App ──────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# ── Email (coordinator digest) ───────────────────────────────────
COORDINATOR_EMAIL=coordinator@wardround.app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=WardRound <noreply@wardround.app>
