# ─────────────────────────────────────────────────────────────
# CareSync Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Auth0 ────────────────────────────────────────────────────
# Found in: Auth0 Dashboard → Applications → your app → Settings
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Found in: Auth0 Dashboard → APIs → your API → Identifier
AUTH0_AUDIENCE=https://wardround-api

# ── Backboard.io ─────────────────────────────────────────────
# Found in: app.backboard.io → Settings → API Keys
BACKBOARD_API_KEY=your_backboard_api_key_here

# Base URL — do not change unless Backboard changes their API
BACKBOARD_BASE_URL=https://app.backboard.io/api

# Found in: app.backboard.io → Assistants → each assistant's ID
# Create three assistants (Handoff, Sentinel, Family) and paste their IDs below
BACKBOARD_HANDOFF_AGENT_ID=your_handoff_assistant_id
BACKBOARD_SENTINEL_AGENT_ID=your_sentinel_assistant_id
BACKBOARD_FAMILY_AGENT_ID=your_family_assistant_id

# ── Vultr Object Storage (S3-compatible) ─────────────────────
# Found in: Vultr Portal → Cloud Storage → Object Storage → your instance → Overview → S3 Credentials
# Note: Toronto is not a Vultr Object Storage region. Use New Jersey (ewr1) as the closest option.
VULTR_STORAGE_ACCESS_KEY=your_s3_access_key
VULTR_STORAGE_SECRET_KEY=your_s3_secret_key
VULTR_STORAGE_ENDPOINT=https://ewr1.vultrobjects.com
VULTR_STORAGE_REGION=ewr1
VULTR_STORAGE_BUCKET=wardround-documents

# ── Vultr Managed Database (PostgreSQL) ──────────────────────
# Found in: Vultr Portal → Databases → your database → Overview → Connection Details → Copy Connection String
# Format: postgresql://vultradmin:PASSWORD@HOST.vultrdb.com:PORT/defaultdb?sslmode=require
DATABASE_URL=postgresql://vultradmin:password@your-host.vultrdb.com:16751/defaultdb?sslmode=require

# ── Redis ────────────────────────────────────────────────────
# Redis runs locally on the VPS. Install with: sudo apt install redis-server
# No changes needed unless you move to a managed Redis instance.
REDIS_URL=redis://localhost:6379

# ── App ──────────────────────────────────────────────────────
PORT=3001
# Set to the frontend URL in production (e.g. https://wardround.app)
CORS_ORIGIN=http://localhost:5173
# Change to 'production' on the live VPS to enable the 2 AM Sentinel cron job
NODE_ENV=development

# ── Email — Coordinator Digest (not yet implemented) ─────────
# These will be used when the coordinator alert email digest is built.
# Recommended: use a Gmail App Password (not your main Gmail password).
COORDINATOR_EMAIL=coordinator@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=CareSync <noreply@caresync.app>
